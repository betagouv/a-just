{
  "name": "cypress",
  "version": "0.0.1",
  "scripts": {
    "start": "npm run cy:open",
    "cy:run": "cypress run --browser electron",
    "cy:open": "cypress open",
    "cy:run:report": "cypress run --browser electron --reporter cypress-mochawesome-reporter",
    "clean:reports": "rm -rf cypress/reports"
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "@cypress/xvfb": "^1.2.4",
    "@ngx-env/builder": "^19.0.4",
    "cy-verify-downloads": "^0.2.6",
    "dotenv": "^17.3.1",
    "install": "^0.13.0",
    "npm": "^11.12.1"
  },
  "devDependencies": {
    "cypress": "^15.13.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "typescript": "~5.5.2",
    "xlsx": "^0.18.5"
  }
}
